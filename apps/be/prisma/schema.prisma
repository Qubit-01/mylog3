generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["typedSql"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "mysql"
}

/// 认证凭证：自有账号（密码）+ 第三方平台 unionid；一组凭证可对应多个 User
model Auth {
  /// 主键
  id            Int      @id @default(autoincrement()) @db.UnsignedInt
  /// 密码 hash（bcrypt）
  pswd          String   @db.VarChar(255)
  /// 邮箱，登录 / 找回密码用
  email         String?  @unique @db.VarChar(100)
  /// 手机号，登录 / 找回密码用
  phone         String?  @unique @db.VarChar(20)
  /// QQ 平台 unionid
  unionidQq     String?  @unique @db.VarChar(255)
  /// 微信平台 unionid
  unionidWeixin String?  @unique @db.VarChar(255)
  /// 更新时间
  updatedAt     DateTime @updatedAt
  /// 创建时间
  createdAt     DateTime @default(now())
  users         User[]
}

/// 用户档案：展示信息与偏好；同一组 Auth 下可有多个 User（如小号）
model User {
  /// 主键
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  /// 所属 Auth 的 id
  authId    Int      @db.UnsignedInt
  /// 用户名，全局唯一
  name      String   @unique @db.VarChar(50)
  /// 头像 URL
  avatar    String?  @db.VarChar(500)
  /// 用户资料（性别、生日、地区、个签等自定义字段），业务层缺省给 `{}`
  data      Json
  /// 用户偏好（主题、语言、通知等），业务层缺省给 `{}`
  settings  Json
  /// 更新时间
  updatedAt DateTime @updatedAt
  /// 创建时间
  createdAt DateTime @default(now())
  logs      Log[]
  auth      Auth     @relation(fields: [authId], references: [id], onDelete: Cascade)

  @@index([authId])
}

/// 用户记录（朋友圈 / 小红书式的图文），JSON 附件的元素形态见字段注释
model Log {
  /// 主键
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  /// 所属 User 的 id
  userId    Int      @db.UnsignedInt
  /// 可见范围：PRIVATE 仅自己 / PUBLIC 完全公开
  scope     LogScope @default(PRIVATE)
  /// 记录时间：内容对应的真实发生时间，允许与 createdAt 分离（补记场景）
  logAt     DateTime
  /// 正文文本，`LongText` 支持长内容
  text      String   @db.LongText
  /// 图片 + 视频列表，按顺序展示用于横滑轮播，缺省 `[]`
  /// - image: `{ type: 'image', name, url, previewUrl?, metadata?: { takenAt?, location?: { lng, lat } } }`
  /// - video: `{ type: 'video', name, url, metadata?: { takenAt?, location?: { lng, lat } } }`
  medias    Json
  /// 音频列表，元素 `{ type: 'audio', name, url }`，缺省 `[]`
  audios    Json
  /// 文件列表，元素 `{ type: 'file', name, url }`，缺省 `[]`
  files     Json
  /// 标签，元素为 string，如 `["生活", "随笔"]`，缺省 `[]`
  tags      Json
  /// 位置列表（地图打点 / 旅行轨迹），元素 `{ lng, lat, name?, address? }`，缺省 `[]`
  location  Json
  /// 关联人员列表，元素 `{ userId?, name?, avatar? }`，缺省 `[]`
  people    Json
  /// 附加信息，任意扩展字段，缺省 `{}`
  extra     Json
  /// 更新时间
  updatedAt DateTime @updatedAt
  /// 创建时间，同时作为对外的发布时间
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
  @@index([userId])
  @@index([createdAt])
}

/// Log 可见范围
enum LogScope {
  /// 仅自己可见
  PRIVATE
  /// 完全公开
  PUBLIC
}
