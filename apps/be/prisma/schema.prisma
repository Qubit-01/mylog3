generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["typedSql"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "mysql"
}

/// 认证表，存储用户登录凭证及第三方平台 unionid
model auth {
  /// 主键 id
  id             Int      @id @default(autoincrement()) @db.UnsignedInt
  /// 登录密码
  pswd           String   @db.VarChar(255)
  /// QQ 平台 unionid
  unionid_qq     String?  @unique @db.VarChar(255)
  /// 微信平台 unionid
  unionid_weixin String?  @unique @db.VarChar(255)
  /// 更新时间
  updated_at     DateTime @updatedAt
  /// 创建时间
  created_at     DateTime @default(now()) @db.DateTime(0)
}
