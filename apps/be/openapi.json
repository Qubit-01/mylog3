{
  "openapi": "3.0.0",
  "paths": {
    "/hello": {
      "get": {
        "operationId": "AppController_hello",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "App"
        ]
      },
      "post": {
        "operationId": "AppController_helloPost",
        "parameters": [],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/captcha/create": {
      "post": {
        "operationId": "CaptchaController_create",
        "parameters": [],
        "responses": {
          "201": {
            "description": "生成一次性图形验证码",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaptchaCreateDto"
                }
              }
            }
          }
        },
        "tags": [
          "captcha"
        ]
      }
    },
    "/auth/register": {
      "post": {
        "operationId": "AuthController_register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "注册成功，token 已写入 httpOnly cookie"
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "登录成功，token 已写入 httpOnly cookie"
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "204": {
            "description": "登出，清除认证 cookie"
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/user/me": {
      "get": {
        "operationId": "UserController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "当前登录用户公开信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicUserDto"
                }
              }
            }
          }
        },
        "tags": [
          "user"
        ]
      }
    },
    "/log/create": {
      "post": {
        "operationId": "LogController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLogDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功，返回新记录",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogDto"
                }
              }
            }
          }
        },
        "tags": [
          "log"
        ]
      }
    },
    "/log/list-public": {
      "post": {
        "operationId": "LogController_listPublic",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogListDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "公开 Log 列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LogDto"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "log"
        ]
      }
    },
    "/log/list-mine": {
      "post": {
        "operationId": "LogController_listMine",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogListDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "我的 Log 列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LogDto"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "log"
        ]
      }
    },
    "/log/get": {
      "post": {
        "operationId": "LogController_get",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogIdDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Log 详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogDto"
                }
              }
            }
          }
        },
        "tags": [
          "log"
        ]
      }
    },
    "/log/update": {
      "post": {
        "operationId": "LogController_update",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateLogDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新后的 Log",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogDto"
                }
              }
            }
          }
        },
        "tags": [
          "log"
        ]
      }
    },
    "/log/delete": {
      "post": {
        "operationId": "LogController_delete",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogIdDto"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "删除成功"
          }
        },
        "tags": [
          "log"
        ]
      }
    }
  },
  "info": {
    "title": "mylog3 API",
    "description": "后端接口文档 — 前端通过 openapi-typescript 生成类型",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CaptchaCreateDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "验证码 id，提交业务接口时回传",
            "example": "uuid-xxx"
          },
          "svg": {
            "type": "string",
            "description": "SVG 文本，前端 v-html 或转 dataURL 直接用"
          }
        },
        "required": [
          "id",
          "svg"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 20,
            "description": "用户昵称，全局唯一",
            "example": "alice"
          },
          "pswd": {
            "type": "string",
            "minLength": 6,
            "description": "登录密码，明文传入，后端 hash 后入库"
          },
          "captchaId": {
            "type": "string",
            "description": "图形验证码 id（/captcha/create 返回的 id）"
          },
          "captcha": {
            "type": "string",
            "description": "图形验证码用户输入"
          }
        },
        "required": [
          "name",
          "pswd",
          "captchaId",
          "captcha"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "用户昵称",
            "example": "alice"
          },
          "pswd": {
            "type": "string",
            "description": "登录密码，明文传入"
          }
        },
        "required": [
          "name",
          "pswd"
        ]
      },
      "PublicUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "用户主键 id",
            "example": 1
          },
          "authId": {
            "type": "number",
            "description": "所属认证 id",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "用户昵称，全局唯一",
            "example": "alice"
          },
          "avatar": {
            "type": "string",
            "nullable": true,
            "description": "头像 URL，未设置为 null",
            "example": "https://cdn.example.com/a.png"
          },
          "data": {
            "type": "object",
            "description": "用户资料（性别、生日、地区、个签等），JSON 对象",
            "example": {}
          },
          "settings": {
            "type": "object",
            "description": "用户偏好设置（主题、语言、通知等），JSON 对象",
            "example": {}
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          }
        },
        "required": [
          "id",
          "authId",
          "name",
          "avatar",
          "data",
          "settings",
          "updatedAt",
          "createdAt"
        ]
      },
      "LogMediaLocationDto": {
        "type": "object",
        "properties": {
          "lng": {
            "type": "number",
            "description": "经度",
            "example": 116.397128
          },
          "lat": {
            "type": "number",
            "description": "纬度",
            "example": 39.916527
          }
        },
        "required": [
          "lng",
          "lat"
        ]
      },
      "LogMediaDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "image",
              "video"
            ],
            "description": "媒体类型：image 图片 / video 视频，MIME 类型前缀",
            "example": "image"
          },
          "url": {
            "type": "string",
            "description": "媒体文件地址或文件名"
          },
          "location": {
            "description": "图片 EXIF 位置坐标",
            "allOf": [
              {
                "$ref": "#/components/schemas/LogMediaLocationDto"
              }
            ]
          }
        },
        "required": [
          "type",
          "url"
        ]
      },
      "CreateLogDto": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "PRIVATE",
              "PUBLIC"
            ],
            "description": "可见范围，默认 PRIVATE",
            "example": "PRIVATE"
          },
          "logAt": {
            "type": "string",
            "format": "date-time",
            "description": "记录时间（ISO 字符串），内容对应的真实发生时间"
          },
          "text": {
            "type": "string",
            "description": "正文文本"
          },
          "medias": {
            "description": "图片 + 视频列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LogMediaDto"
            }
          },
          "audios": {
            "description": "音频列表",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "files": {
            "description": "文件列表",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "tags": {
            "description": "标签列表",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "location": {
            "description": "位置坐标列表",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "people": {
            "description": "关联人员列表",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "extra": {
            "type": "object",
            "description": "附加信息"
          }
        },
        "required": [
          "logAt"
        ]
      },
      "LogDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "Log 主键 id",
            "example": 1
          },
          "userId": {
            "type": "number",
            "description": "所属用户 id",
            "example": 1
          },
          "scope": {
            "type": "string",
            "enum": [
              "PRIVATE",
              "PUBLIC"
            ],
            "description": "可见范围：PRIVATE 仅自己 / PUBLIC 完全公开",
            "example": "PRIVATE"
          },
          "logAt": {
            "type": "string",
            "format": "date-time",
            "description": "记录时间，内容对应的真实发生时间"
          },
          "text": {
            "type": "string",
            "description": "正文文本",
            "example": ""
          },
          "medias": {
            "description": "图片 + 视频列表",
            "example": [],
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LogMediaDto"
            }
          },
          "audios": {
            "description": "音频列表，元素 `{ url, duration?, title? }`",
            "example": [],
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "files": {
            "description": "文件列表，元素 `{ url, name, size?, mime? }`",
            "example": [],
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "tags": {
            "description": "标签列表",
            "example": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "location": {
            "description": "位置坐标列表，元素 `{ lng, lat, name?, address?, time? }`",
            "example": [],
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "people": {
            "description": "关联人员列表，元素 `{ userId?, name?, avatar? }`",
            "example": [],
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "extra": {
            "type": "object",
            "description": "附加信息，JSON 对象",
            "example": {}
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间，同时作为对外发送时间"
          }
        },
        "required": [
          "id",
          "userId",
          "scope",
          "logAt",
          "text",
          "medias",
          "audios",
          "files",
          "tags",
          "location",
          "people",
          "extra",
          "updatedAt",
          "createdAt"
        ]
      },
      "LogListDto": {
        "type": "object",
        "properties": {
          "skip": {
            "type": "number",
            "minimum": 0,
            "description": "跳过的条数，缺省 0"
          },
          "take": {
            "type": "number",
            "minimum": 1,
            "maximum": 100,
            "description": "取的条数，缺省 20，最大 100"
          }
        }
      },
      "LogIdDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "目标 Log id"
          }
        },
        "required": [
          "id"
        ]
      },
      "UpdateLogDto": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "PRIVATE",
              "PUBLIC"
            ],
            "description": "可见范围，默认 PRIVATE",
            "example": "PRIVATE"
          },
          "logAt": {
            "type": "string",
            "format": "date-time",
            "description": "记录时间（ISO 字符串），内容对应的真实发生时间"
          },
          "text": {
            "type": "string",
            "description": "正文文本"
          },
          "medias": {
            "description": "图片 + 视频列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LogMediaDto"
            }
          },
          "audios": {
            "description": "音频列表",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "files": {
            "description": "文件列表",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "tags": {
            "description": "标签列表",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "location": {
            "description": "位置坐标列表",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "people": {
            "description": "关联人员列表",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "extra": {
            "type": "object",
            "description": "附加信息"
          },
          "id": {
            "type": "number",
            "description": "要更新的 Log id"
          }
        },
        "required": [
          "id"
        ]
      }
    }
  }
}